generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js Required Models ──────────────────────────────────────

model Account {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  type              String
  provider          String
  providerAccountId String   @map("provider_account_id")
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Application Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // CollectorFlex profile
  username       String? @unique
  displayName    String? @map("display_name")
  bio            String?
  contactDiscord String? @map("contact_discord")
  contactTwitter String? @map("contact_twitter")
  contactEmail   String? @map("contact_email")

  accounts  Account[]
  sessions  Session[]
  showcases Showcase[]
  takes     Take[]

  @@map("users")
}

model Showcase {
  id          String   @id @default(cuid())
  name        String
  platform    String
  description String?
  coverImage  String?  @map("cover_image")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items ShowcaseItem[]

  @@map("showcases")
}

model ShowcaseItem {
  id           String   @id @default(cuid())
  title        String
  platformUrl  String   @map("platform_url")
  story        String?  @db.Text
  acquiredDate String?  @map("acquired_date")
  tags         String[]
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  showcaseId String   @map("showcase_id")
  showcase   Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)

  @@map("showcase_items")
}

model Take {
  id            String   @id @default(cuid())
  title         String
  excerpt       String
  content       String   @db.Text
  publishedAt   DateTime @default(now()) @map("published_at")
  collectionTag String?  @map("collection_tag")
  readTime      String?  @map("read_time")
  thumbnailUrl  String?  @map("thumbnail_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("takes")
}
